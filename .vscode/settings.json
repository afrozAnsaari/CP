{
    // Treat C++ headers correctly
    "files.associations": {
        "iostream": "cpp",
        "*.h": "cpp",
        "iosfwd": "cpp"
    },

    // Enable basic keyword suggestions AND variable names from current file
    "editor.quickSuggestions": {
        "other": true,       // language keywords like for, if, else
        "comments": false,
        "strings": false
    },

    // Enable word-based suggestions from your current file
    "editor.wordBasedSuggestions": "matchingDocuments",

    // Disable inline ghost suggestions (gray faded text)
    "editor.inlineSuggest.enabled": false,

    // Disable AI/extension suggestions
    "github.copilot.enable": {
        "*": false
    },

    // Disable parameter hints if you don’t want function signature popups
    "editor.parameterHints.enabled": false,

    // Optional: Disable error squiggles
    "C_Cpp.errorSquiggles": "Disabled",

    // Optional: clean font for coding
    "editor.fontFamily": "Fira Code, monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 14
}
